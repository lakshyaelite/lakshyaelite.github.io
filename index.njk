---
layout: layouts/base.njk
title: Lakshya Singh Chauhan
description: Portfolio and blog of Lakshya Singh Chauhan — The Web Developer. Thoughts, tutorials, and insights on web development.
---

<header class="hero-section text-center">
    <div class="container">

        <div class="profile-container mb-4">
            <img
                src="/lakshya.jpg"
                alt="Lakshya Singh Chauhan profile photo"
                class="profile-img shadow-lg"
                width="250"
                height="250"
                decoding="async"
                fetchpriority="high"
            >
        </div>

        <h1 class="display-4 fw-bold mb-2">{{ site.name }}</h1>
        <p class="lead mb-4 text-secondary">{{ site.tagline }}</p>

        <div class="social-links mb-5">
            {% for key, url in site.social %}
            {% if url and url != "#" %}
            <a href="{{ url }}" class="social-icon" aria-label="{{ key }}" target="_blank" rel="noopener noreferrer">
                <i class="fab fa-{{ key }}"></i>
            </a>
            {% endif %}
            {% endfor %}

            {% if site.email %}
            <a href="mailto:{{ site.email }}" class="social-icon" aria-label="Email">
                <i class="fas fa-envelope"></i>
            </a>
            {% endif %}
        </div>
        <i class="bi bi-chevron-down" id="down-arrow-thing"></i>

    </div>
</header>


<section id="blog" class="py-5 bg-soft">
    <div class="container">

        <div class="section-header text-center mb-5">
            <h2 class="fw-bold">Latest Blog Posts</h2>
            <div class="underline mx-auto"></div>
        </div>

        <div class="row justify-content-center g-4">

            {% for post in (collections.posts | batch(3) | first) %}
            <div class="col-md-6 col-lg-4">

                <div class="card h-100 shadow-sm">

                    {% if post.data.cover %}
                    <img
                        src="{{ post.data.cover }}"
                        alt="{{ post.data.title }} cover image"
                        class="card-img-top"
                        loading="lazy"
                        decoding="async"
                    >
                    {% endif %}

                    <div class="card-body p-4">

                        <h5 class="card-title fw-bold">
                            <a href="{{ post.url }}" class="text-decoration-none">
                                {{ post.data.title }}
                            </a>
                        </h5>

                        <p class="card-text text-muted small mb-3">
                            {{ post.data.description or post.templateContent | striptags | truncate(100) }}
                        </p>

                        <div class="d-flex justify-content-between align-items-center">

                            <div class="d-flex gap-3">
                                <small class="text-muted">
                                    {{ post.date | dateDisplay }}
                                </small>

                                <small class="text-muted reading-time">
                                    <i class="bi bi-stopwatch-fill"></i>
                                    {{ post.templateContent | readingTime }}
                                </small>
                            </div>

                            <a href="{{ post.url }}" class="btn btn-outline-primary btn-sm rounded-pill">
                                Read More
                            </a>

                        </div>

                    </div>

                </div>

            </div>
            {% endfor %}

        </div>

        <div class="text-center mt-4">
            <a href="/blog/" class="btn btn-primary rounded-pill px-4">
                View All Posts
            </a>
        </div>

    </div>
</section>


<section id="projects" class="py-5">
    <div class="container">

        <div class="section-header text-center mb-5">
            <h2 class="fw-bold">Latest Projects</h2>
            <div class="underline mx-auto"></div>
        </div>

        <div class="row justify-content-center g-4" id="project-container"></div>

    </div>
</section>


<section id="certificates" class="py-5 bg-soft">
    <div class="container">

        <div class="section-header text-center mb-5">
            <h2 class="fw-bold">Certifications</h2>
            <div class="underline mx-auto"></div>
        </div>

        <div class="row justify-content-center g-4" id="certificate-container"></div>

    </div>
</section>


<section id="contact" class="py-5 mb-5">
    <div class="container">

        <div class="row justify-content-center">

            <div class="col-md-7">

                <div class="contact-card p-5 shadow-lg border-0 rounded-4">

                    <h2 class="text-center mb-4 fw-bold">
                        Let's Collaborate
                    </h2>

                    <form id="emailForm" data-email="{{ site.email }}">

                        <div class="mb-3">
                            <label class="form-label fw-semibold">
                                Subject
                            </label>

                            <input
                                type="text"
                                id="subject"
                                class="form-control form-control-lg bg-light border-0"
                                placeholder="What's on your mind?"
                                required
                            >
                        </div>

                        <div class="mb-4">

                            <label class="form-label fw-semibold">
                                Your Message
                            </label>

                            <textarea
                                id="message"
                                class="form-control form-control-lg bg-light border-0"
                                rows="4"
                                placeholder="Type your message here..."
                                required
                            ></textarea>

                        </div>

                        <button
                            type="submit"
                            class="btn btn-primary btn-lg w-100 rounded-pill shadow-sm"
                        >
                            <i class="fas fa-paper-plane me-2"></i>
                            Send
                        </button>

                    </form>

                </div>

            </div>

        </div>

    </div>
</section>